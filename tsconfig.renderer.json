{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "outDir": "./renderer",
    "rootDir": "./renderer",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "sourceMap": true,
    "allowJs": true
  },
  "include": ["renderer/**/*"],
  "exclude": ["node_modules", "dist", "src", "renderer/marked.umd.js", "renderer/purify.min.js"]
}